generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(dbgenerated("concat('usr_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  email         String         @unique
  password      String?
  name          String?
  avatar        String?
  isOnboarded   Boolean        @default(false)
  aiCredits     Int            @default(10)
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  profession    String
  folders       Folder[]
  presentations Presentation[]
}

model Folder {
  id            String         @id @default(dbgenerated("concat('fld_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  name          String
  isPinned      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  parentId      String?
  parent        Folder?        @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children      Folder[]       @relation("FolderToFolder")
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  presentations Presentation[]

  @@index([userId])
  @@index([parentId])
  @@index([userId, isPinned])
}

model Presentation {
  id        String   @id @default(dbgenerated("concat('prs_', replace((gen_random_uuid())::text, '-'::text, ''::text))"))
  title     String
  content   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  folderId  String?
  folder    Folder?  @relation(fields: [folderId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([folderId])
}

model EmailOTP {
  id             String     @id @default(cuid())
  email          String
  otp            String
  hashedPassword String?
  expiresAt      DateTime
  createdAt      DateTime   @default(now())
  purpose        OTPPurpose @default(SIGNUP)

  @@index([email])
  @@index([email, purpose])
}

enum Role {
  USER
  ADMIN
  PRO
}

enum OTPPurpose {
  SIGNUP
  PASSWORD_RESET
}
